/* 致安组件库 - 组件样式 */

/* ========== Button 按钮 ========== */
.za-button {
    min-width: 20vw;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2vw 3vw;
    border-radius: 5vw;
    font-size: 3.5vw;
    line-height: 4.5vw;
    background: var(--button-background-color);
    color: var(--button-text);
    font-family: mipro-medium, miui-bold, mipro, miui, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "微软雅黑", Arial, sans-serif;
    font-weight: 400;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
}

.za-button:active {
    transform: scale(0.95);
}

.za-button-primary {
    color: #fff;
    background-color: var(--theme-color);
}

.za-button-small {
    min-width: 12vw;
    width: fit-content;
    height: fit-content;
    font-size: 3vw;
    line-height: 3.8vw;
    border-radius: 4vw;
    padding: 1.5vw 2.5vw;
    color: var(--theme-color);
    background-color: rgba(13, 132, 255, 0.1);
}

.za-button-small.za-button-primary {
    color: #fff;
    background-color: var(--theme-color);
}

.za-button-disable {
    pointer-events: none;
    color: var(--text-3);
    opacity: 0.5;
}

@media screen and (min-width: 670px) {
    .za-button {
        min-width: 22.25vw;
        width: 22.25vw;
        padding: 1.875vw 0;
        border-radius: 5vw;
        font-size: 2.25vw;
        line-height: 3.25vw;
    }
    
    .za-button-small {
        min-width: unset;
        width: fit-content;
        font-size: 1.875vw;
        line-height: 2.5625vw;
        padding: 1.0625vw 2.875vw;
    }
}

@media screen and (min-width: 900px) {
    .za-button {
        min-width: 120px;
        width: auto;
        padding: 10px 24px;
        border-radius: 20px;
        font-size: 14px;
        line-height: 20px;
    }
    
    .za-button-small {
        min-width: auto;
        width: fit-content;
        font-size: 12px;
        line-height: 18px;
        padding: 6px 16px;
        border-radius: 16px;
    }
}

/* ========== Card 卡片 ========== */
.za-card {
    background: var(--card-background);
    border: 1px solid var(--divider-color);
    box-shadow: var(--card-shadow);
    border-radius: 2.5vw;
    padding: 3.5vw;
    margin-bottom: 2.5vw;
}

.za-card-title {
    font-size: 3.8vw;
    line-height: 5vw;
    color: var(--text-title-color);
    font-family: mipro-medium, miui-bold, mipro, miui, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "微软雅黑", Arial, sans-serif;
    font-weight: 400;
    margin-bottom: 2vw;
}

.za-card-content {
    font-size: 3vw;
    line-height: 4.5vw;
    color: var(--text-secondary-color);
}

@media screen and (min-width: 670px) {
    .za-card {
        border-radius: 2.25vw;
        padding: 3.75vw;
        margin-bottom: 2.5vw;
    }
    
    .za-card-title {
        font-size: 2.375vw;
        line-height: 3.125vw;
        margin-bottom: 1.875vw;
    }
    
    .za-card-content {
        font-size: 2vw;
        line-height: 3vw;
    }
}

@media screen and (min-width: 900px) {
    .za-card {
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
    }
    
    .za-card-title {
        font-size: 16px;
        line-height: 24px;
        margin-bottom: 12px;
    }
    
    .za-card-content {
        font-size: 14px;
        line-height: 22px;
    }
}

/* ========== ListItem 列表项 ========== */
.za-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 3vw 4vw;
    background: var(--background-color);
    border-bottom: 0.7px solid var(--divider-color);
    cursor: pointer;
    transition: background 0.3s;
}

.za-list-item:active {
    background: var(--shadow-color);
}

.za-list-item-label-wrap {
    flex: 1;
}

.za-list-item-label {
    font-size: 3.5vw;
    line-height: 4.5vw;
    color: var(--text-title-color);
    font-family: mipro-medium, miui-bold, mipro, miui, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "微软雅黑", Arial, sans-serif;
    font-weight: 400;
}

.za-list-item-desc {
    font-size: 2.8vw;
    line-height: 3.8vw;
    color: var(--text-secondary-color);
    margin-top: 1vw;
}

.za-list-item-slot {
    font-size: 3vw;
    line-height: 3.8vw;
    color: var(--text-6);
    margin-left: 2vw;
}

.za-list-item-arrow {
    width: 1.5vw;
    height: 1.5vw;
    margin-left: 2vw;
    opacity: 0.3;
}

@media screen and (min-width: 670px) {
    .za-list-item {
        padding: 2.5vw 4.375vw;
    }
    
    .za-list-item-label {
        font-size: 2.25vw;
        line-height: 3vw;
    }
    
    .za-list-item-desc {
        font-size: 1.875vw;
        line-height: 2.5vw;
        margin-top: 0.9375vw;
    }
    
    .za-list-item-slot {
        font-size: 2vw;
        line-height: 2.625vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-list-item {
        padding: 1.5625vw 2.734375vw;
    }
    
    .za-list-item-label {
        font-size: 1.40625vw;
        line-height: 1.875vw;
    }
    
    .za-list-item-desc {
        font-size: 1.171875vw;
        line-height: 1.5625vw;
        margin-top: 0.585938vw;
    }
    
    .za-list-item-slot {
        font-size: 1.25vw;
        line-height: 1.640625vw;
    }
}

/* ========== Switch 开关 ========== */
.za-switch {
    position: relative;
    width: 10vw;
    height: 5.5vw;
    background: var(--button-background-color);
    border-radius: 2.75vw;
    cursor: pointer;
    transition: background 0.3s;
}

.za-switch-point {
    position: absolute;
    top: 0.7vw;
    left: 0.7vw;
    width: 4.1vw;
    height: 4.1vw;
    background: #fff;
    border-radius: 50%;
    transition: all 0.3s cubic-bezier(0.3, 0, 0, 1);
    box-shadow: 0 0.5vw 1.2vw rgba(0, 0, 0, 0.2);
}

.za-switch[data-checked="true"] {
    background: var(--theme-color);
}

.za-switch[data-checked="true"] .za-switch-point {
    left: 5.2vw;
}

@media screen and (min-width: 670px) {
    .za-switch {
        width: 8.75vw;
        height: 5vw;
        border-radius: 2.5vw;
    }
    
    .za-switch-point {
        top: 0.625vw;
        left: 0.625vw;
        width: 3.75vw;
        height: 3.75vw;
    }
    
    .za-switch[data-checked="true"] .za-switch-point {
        left: 4.375vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-switch {
        width: 5.46875vw;
        height: 3.125vw;
        border-radius: 1.5625vw;
    }
    
    .za-switch-point {
        top: 0.390625vw;
        left: 0.390625vw;
        width: 2.34375vw;
        height: 2.34375vw;
    }
    
    .za-switch[data-checked="true"] .za-switch-point {
        left: 2.734375vw;
    }
}

/* ========== Toast 提示 ========== */
.za-toast-container {
    pointer-events: none;
    z-index: 1000;
    position: fixed;
    top: 100vh;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    transform: translateY(-100%);
}

.za-toast {
    overflow: hidden;
    margin: 0 8vw;
    box-sizing: border-box;
    padding: 2vw 3vw;
    background: var(--toast-background);
    border: 0.7px solid var(--toast-border);
    box-shadow: 0 2vw 4vw 0 rgba(0, 0, 0, 0.05), 0 2.5vw 5vw 0 rgba(0, 0, 0, 0.05);
    border-radius: 2.5vw;
    text-align: center;
    opacity: 0;
    transform: translateY(0) scale(0.5);
    transition-property: opacity, transform;
    transition-duration: 0.3s;
    transition-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.za-toast-text {
    text-overflow: ellipsis;
    overflow: hidden;
    height: 100%;
    user-select: initial;
    opacity: 0.8;
    font-size: 3vw;
    color: var(--text-primary-color);
    letter-spacing: 0;
    text-align: center;
}

.za-toast.show {
    opacity: 1;
    transform: translateY(-20vw) scale(1);
}

.za-toast.hide {
    opacity: 0;
    transform: translateY(0) scale(1);
}

@media screen and (min-width: 670px) {
    .za-toast {
        margin: 0 5.625vw;
        padding: 2.1875vw 2.5vw;
        border: 1px solid var(--toast-border);
        box-shadow: 0 2.5vw 5vw 0 rgba(0, 0, 0, 0.05), 0 3.125vw 6.25vw 0 rgba(0, 0, 0, 0.05);
        border-radius: 2.25vw;
    }
    
    .za-toast-text {
        font-size: 2.25vw;
    }
    
    .za-toast.show {
        transform: translateY(-18.75vw) scale(1);
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-toast {
        margin: 0 3.515625vw;
        padding: 1.367188vw 1.5625vw;
        border: 1px solid var(--toast-border);
        box-shadow: 0 1.5625vw 3.125vw 0 rgba(0, 0, 0, 0.05), 0 1.953125vw 3.90625vw 0 rgba(0, 0, 0, 0.05);
        border-radius: 1.40625vw;
    }
    
    .za-toast-text {
        font-size: 1.40625vw;
    }
    
    .za-toast.show {
        transform: translateY(-11.71875vw) scale(1);
    }
}

/* ========== Modal 模态框 ========== */
.za-modal-mask {
    z-index: 30;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    background-color: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.28s cubic-bezier(0.3, 0, 0, 1);
}

.za-modal-mask.show {
    pointer-events: all;
    opacity: 1;
}

.za-modal-mask.hide {
    opacity: 0;
}

.za-modal-container {
    z-index: 30;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    border-top-left-radius: 4vw;
    border-top-right-radius: 4vw;
    transform: translate3d(0, 100%, 0);
    background-color: var(--modal-background-color);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding-top: 2vw;
    transition: transform 0.28s cubic-bezier(0.3, 0, 0, 1);
}

.za-modal-container.show {
    transform: translateZ(0);
}

.za-modal-container.hide {
    transform: translate3d(0, 100%, 0);
}

.za-modal-title {
    height: fit-content;
    padding: 0 4vw;
}

.za-modal-title-text {
    font-size: 3.8vw;
    line-height: 5vw;
    color: var(--text-title-color);
    font-family: mipro-medium, miui-bold, mipro, miui, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "微软雅黑", Arial, sans-serif;
    font-weight: 400;
}

.za-modal-content {
    margin: 0;
    overflow: scroll;
    flex: 1;
    padding: 3.5vw 4vw;
}

.za-modal-footer {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    padding: 0 4vw 4vw;
}

@media screen and (min-width: 670px) {
    .za-modal-container {
        position: relative;
        pointer-events: none;
        opacity: 0;
        max-width: 77.5vw;
        max-height: 85vw;
        border-radius: 3vw;
        padding-bottom: 0;
        transform: translateZ(0);
        margin: auto;
        top: 50%;
        bottom: auto;
        left: 50%;
        right: auto;
        transform: translate(-50%, -50%) scale(0.5);
    }
    
    .za-modal-container.show {
        pointer-events: all;
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
    
    .za-modal-container.hide {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.5);
    }
    
    .za-modal-title {
        padding: 0 4.07875vw;
    }
    
    .za-modal-title-text {
        font-size: 2.375vw;
        line-height: 3.125vw;
    }
    
    .za-modal-content {
        padding: 3.75vw 4.07875vw;
    }
    
    .za-modal-footer {
        padding: 0 3.25vw 3.25vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-modal-container {
        max-width: 48.4375vw;
        max-height: 53.125vw;
        border-radius: 1.875vw;
    }
    
    .za-modal-title {
        padding: 0 2.549219vw;
    }
    
    .za-modal-title-text {
        font-size: 1.484375vw;
        line-height: 1.953125vw;
    }
    
    .za-modal-content {
        padding: 2.34375vw 2.549219vw;
    }
    
    .za-modal-footer {
        padding: 0 2.03125vw 2.03125vw;
    }
}

/* ========== Loading 加载 ========== */
.za-loading {
    width: 4vw;
    height: 4vw;
    border: 0.5vw solid var(--text-4);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    position: relative;
}

.za-loading-point {
    width: 0.6vw;
    height: 100%;
    position: relative;
    animation: za-rotate 0.8s linear infinite forwards;
}

.za-loading-point::before {
    content: " ";
    display: inline-block;
    position: absolute;
    top: 16%;
    left: 50%;
    transform: translateX(-50%);
    width: 1vw;
    height: 1vw;
    border-radius: 0.5vw;
    background-color: var(--text-4);
}

@keyframes za-rotate {
    0% {
        transform: rotate(0);
    }
    100% {
        transform: rotate(360deg);
    }
}

@media screen and (min-width: 670px) {
    .za-loading {
        width: 3.125vw;
        height: 3.125vw;
        border: 0.375vw solid var(--text-4);
    }
    
    .za-loading-point {
        width: 0.375vw;
    }
    
    .za-loading-point::before {
        width: 0.75vw;
        height: 0.75vw;
        border-radius: 0.375vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-loading {
        width: 1.953125vw;
        height: 1.953125vw;
        border: 0.234375vw solid var(--text-4);
    }
    
    .za-loading-point {
        width: 0.234375vw;
    }
    
    .za-loading-point::before {
        width: 0.46875vw;
        height: 0.46875vw;
        border-radius: 0.234375vw;
    }
}

/* ========== Icon 图标 ========== */
.za-icon {
    fill: currentColor;
    background-size: cover;
    width: 6vw;
    height: 6vw;
    font-size: 6vw;
    vertical-align: middle;
    color: var(--icon-color);
}

.za-icon-xs {
    width: 4vw;
    height: 4vw;
    font-size: 4vw;
}

.za-icon-sm {
    width: 5vw;
    height: 5vw;
    font-size: 5vw;
}

.za-icon-md {
    width: 6vw;
    height: 6vw;
    font-size: 6vw;
}

.za-icon-lg {
    width: 8vw;
    height: 8vw;
    font-size: 8vw;
}

@media screen and (min-width: 670px) {
    .za-icon-xs {
        width: 4.75vw;
        height: 4.75vw;
        font-size: 4.75vw;
    }
    
    .za-icon-md {
        width: 6.25vw;
        height: 6.25vw;
        font-size: 6.25vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-icon-xs {
        width: 2.96875vw;
        height: 2.96875vw;
        font-size: 2.96875vw;
    }
    
    .za-icon-md {
        width: 3.90625vw;
        height: 3.90625vw;
        font-size: 3.90625vw;
    }
}

/* ========== Input 输入框 ========== */
.za-input {
    width: 100%;
    padding: 3vw 4vw;
    font-size: 3.5vw;
    line-height: 4.5vw;
    color: var(--text-title-color);
    background: var(--background-color);
    border: 0.7px solid var(--divider-color);
    border-radius: 2.5vw;
    outline: none;
    font-family: inherit;
    transition: border-color 0.3s;
}

.za-input:focus {
    border-color: var(--theme-color);
}

.za-input::placeholder {
    color: var(--text-4);
}

.za-input-group {
    margin-bottom: 3vw;
}

.za-input-label {
    display: block;
    font-size: 3vw;
    line-height: 4vw;
    color: var(--text-6);
    margin-bottom: 1.5vw;
}

@media screen and (min-width: 670px) {
    .za-input {
        padding: 2.5vw 3.5vw;
        font-size: 2.25vw;
        line-height: 3vw;
        border-radius: 2.25vw;
    }
    
    .za-input-label {
        font-size: 2vw;
        line-height: 2.625vw;
        margin-bottom: 1.25vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-input {
        padding: 1.5625vw 2.1875vw;
        font-size: 1.40625vw;
        line-height: 1.875vw;
        border-radius: 1.40625vw;
    }
    
    .za-input-label {
        font-size: 1.25vw;
        line-height: 1.640625vw;
        margin-bottom: 0.78125vw;
    }
}

/* ========== Divider 分割线 ========== */
.za-divider {
    border: none;
    height: 0.7px;
    background-color: var(--divider-color);
    margin: 4vw 0;
}

.za-divider-text {
    display: flex;
    align-items: center;
    margin: 4vw 0;
    font-size: 3vw;
    color: var(--text-6);
}

.za-divider-text::before,
.za-divider-text::after {
    content: '';
    flex: 1;
    height: 0.7px;
    background-color: var(--divider-color);
}

.za-divider-text::before {
    margin-right: 2vw;
}

.za-divider-text::after {
    margin-left: 2vw;
}

@media screen and (min-width: 670px) {
    .za-divider {
        margin: 3.75vw 0;
    }
    
    .za-divider-text {
        margin: 3.75vw 0;
        font-size: 2vw;
    }
    
    .za-divider-text::before {
        margin-right: 1.5vw;
    }
    
    .za-divider-text::after {
        margin-left: 1.5vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-divider {
        margin: 2.34375vw 0;
    }
    
    .za-divider-text {
        margin: 2.34375vw 0;
        font-size: 1.25vw;
    }
    
    .za-divider-text::before {
        margin-right: 0.9375vw;
    }
    
    .za-divider-text::after {
        margin-left: 0.9375vw;
    }
}

/* ========== Tag 标签 ========== */
.za-tag {
    display: inline-flex;
    align-items: center;
    padding: 1vw 2.5vw;
    font-size: 2.8vw;
    line-height: 3.5vw;
    border-radius: 3vw;
    background: var(--button-background-color);
    color: var(--text-7);
    border: none;
}

.za-tag-primary {
    background: var(--theme-color-light);
    color: var(--theme-color);
}

.za-tag-success {
    background: rgba(82, 196, 26, 0.1);
    color: #52c41a;
}

.za-tag-warning {
    background: var(--system-yellow-background);
    color: var(--system-yellow);
}

.za-tag-danger {
    background: var(--system-red-background);
    color: var(--system-red);
}

.za-tag-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 1.5vw;
    width: 3.5vw;
    height: 3.5vw;
    cursor: pointer;
    font-size: 3vw;
    border-radius: 50%;
    transition: background 0.3s;
}

.za-tag-close:hover {
    background: rgba(0, 0, 0, 0.1);
}

@media screen and (min-width: 670px) {
    .za-tag {
        padding: 0.75vw 2vw;
        font-size: 1.875vw;
        line-height: 2.5vw;
        border-radius: 2.25vw;
    }
    
    .za-tag-close {
        margin-left: 1.125vw;
        width: 2.5vw;
        height: 2.5vw;
        font-size: 2vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-tag {
        padding: 0.46875vw 1.25vw;
        font-size: 1.171875vw;
        line-height: 1.5625vw;
        border-radius: 1.40625vw;
    }
    
    .za-tag-close {
        margin-left: 0.703125vw;
        width: 1.5625vw;
        height: 1.5625vw;
        font-size: 1.25vw;
    }
}

/* ========== Checkbox 复选框 ========== */
.za-checkbox {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
}

.za-checkbox-input {
    position: relative;
    width: 4.5vw;
    height: 4.5vw;
    border: 0.7px solid var(--divider-color);
    border-radius: 1vw;
    background: var(--background-color);
    transition: all 0.3s;
}

.za-checkbox-input::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 2.5vw;
    height: 2.5vw;
    background: var(--theme-color);
    border-radius: 0.5vw;
    transition: transform 0.3s;
}

.za-checkbox[data-checked="true"] .za-checkbox-input {
    border-color: var(--theme-color);
    background: var(--theme-color-light);
}

.za-checkbox[data-checked="true"] .za-checkbox-input::after {
    transform: translate(-50%, -50%) scale(1);
}

.za-checkbox-label {
    margin-left: 2vw;
    font-size: 3.5vw;
    line-height: 4.5vw;
    color: var(--text-title-color);
}

@media screen and (min-width: 670px) {
    .za-checkbox-input {
        width: 3.5vw;
        height: 3.5vw;
        border-radius: 0.75vw;
    }
    
    .za-checkbox-input::after {
        width: 2vw;
        height: 2vw;
        border-radius: 0.375vw;
    }
    
    .za-checkbox-label {
        margin-left: 1.5vw;
        font-size: 2.25vw;
        line-height: 3vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-checkbox-input {
        width: 2.1875vw;
        height: 2.1875vw;
        border-radius: 0.46875vw;
    }
    
    .za-checkbox-input::after {
        width: 1.25vw;
        height: 1.25vw;
        border-radius: 0.234375vw;
    }
    
    .za-checkbox-label {
        margin-left: 0.9375vw;
        font-size: 1.40625vw;
        line-height: 1.875vw;
    }
}

/* ========== Radio 单选框 ========== */
.za-radio {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
}

.za-radio-input {
    position: relative;
    width: 4.5vw;
    height: 4.5vw;
    border: 0.7px solid var(--divider-color);
    border-radius: 50%;
    background: var(--background-color);
    transition: all 0.3s;
}

.za-radio-input::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 2.5vw;
    height: 2.5vw;
    background: var(--theme-color);
    border-radius: 50%;
    transition: transform 0.3s;
}

.za-radio[data-checked="true"] .za-radio-input {
    border-color: var(--theme-color);
}

.za-radio[data-checked="true"] .za-radio-input::after {
    transform: translate(-50%, -50%) scale(1);
}

.za-radio-label {
    margin-left: 2vw;
    font-size: 3.5vw;
    line-height: 4.5vw;
    color: var(--text-title-color);
}

@media screen and (min-width: 670px) {
    .za-radio-input {
        width: 3.5vw;
        height: 3.5vw;
    }
    
    .za-radio-input::after {
        width: 2vw;
        height: 2vw;
    }
    
    .za-radio-label {
        margin-left: 1.5vw;
        font-size: 2.25vw;
        line-height: 3vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-radio-input {
        width: 2.1875vw;
        height: 2.1875vw;
    }
    
    .za-radio-input::after {
        width: 1.25vw;
        height: 1.25vw;
    }
    
    .za-radio-label {
        margin-left: 0.9375vw;
        font-size: 1.40625vw;
        line-height: 1.875vw;
    }
}

/* ========== Progress 进度条 ========== */
.za-progress {
    width: 100%;
    height: 1.5vw;
    background: var(--button-background-color);
    border-radius: 0.75vw;
    overflow: hidden;
}

.za-progress-bar {
    height: 100%;
    background: var(--theme-color);
    border-radius: 0.75vw;
    transition: width 0.3s;
}

.za-progress-text {
    margin-top: 1.5vw;
    font-size: 2.8vw;
    color: var(--text-6);
    text-align: center;
}

@media screen and (min-width: 670px) {
    .za-progress {
        height: 1.125vw;
        border-radius: 0.5625vw;
    }
    
    .za-progress-bar {
        border-radius: 0.5625vw;
    }
    
    .za-progress-text {
        margin-top: 1.125vw;
        font-size: 1.875vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-progress {
        height: 0.703125vw;
        border-radius: 0.351563vw;
    }
    
    .za-progress-bar {
        border-radius: 0.351563vw;
    }
    
    .za-progress-text {
        margin-top: 0.703125vw;
        font-size: 1.171875vw;
    }
}

/* ========== Badge 徽章 ========== */
.za-badge {
    position: relative;
    display: inline-block;
}

.za-badge-dot {
    position: absolute;
    top: 0;
    right: 0;
    width: 2vw;
    height: 2vw;
    background: var(--system-red);
    border-radius: 50%;
    border: 0.5vw solid var(--background-color);
}

.za-badge-count {
    position: absolute;
    top: -1vw;
    right: -1vw;
    min-width: 4vw;
    height: 4vw;
    padding: 0 1vw;
    background: var(--system-red);
    color: #fff;
    font-size: 2.5vw;
    line-height: 4vw;
    text-align: center;
    border-radius: 2vw;
    border: 0.5vw solid var(--background-color);
}

@media screen and (min-width: 670px) {
    .za-badge-dot {
        width: 1.5vw;
        height: 1.5vw;
        border: 0.375vw solid var(--background-color);
    }
    
    .za-badge-count {
        top: -0.75vw;
        right: -0.75vw;
        min-width: 3vw;
        height: 3vw;
        padding: 0 0.75vw;
        font-size: 1.875vw;
        line-height: 3vw;
        border-radius: 1.5vw;
        border: 0.375vw solid var(--background-color);
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-badge-dot {
        width: 0.9375vw;
        height: 0.9375vw;
        border: 0.234375vw solid var(--background-color);
    }
    
    .za-badge-count {
        top: -0.46875vw;
        right: -0.46875vw;
        min-width: 1.875vw;
        height: 1.875vw;
        padding: 0 0.46875vw;
        font-size: 1.171875vw;
        line-height: 1.875vw;
        border-radius: 0.9375vw;
        border: 0.234375vw solid var(--background-color);
    }
}

/* ========== Navbar 导航栏 ========== */
.za-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 12vw;
    background: var(--background-color);
    border-bottom: 0.7px solid var(--divider-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 4vw;
    z-index: 100;
}

.za-navbar-left,
.za-navbar-right {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
}

.za-navbar-title {
    flex: 1;
    text-align: center;
    font-size: 4vw;
    line-height: 5.5vw;
    color: var(--text-title-color);
    font-family: mipro-medium, miui-bold, mipro, miui, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "微软雅黑", Arial, sans-serif;
    font-weight: 400;
}

@media screen and (min-width: 670px) {
    .za-navbar {
        height: 8vw;
        padding: 0 3.5vw;
    }
    
    .za-navbar-title {
        font-size: 2.5vw;
        line-height: 3.5vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-navbar {
        height: 5vw;
        padding: 0 2.1875vw;
    }
    
    .za-navbar-title {
        font-size: 1.5625vw;
        line-height: 2.1875vw;
    }
}

/* ========== Notification 通知 ========== */
.za-notification {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--toast-background);
    border-top: 0.7px solid var(--toast-border);
    box-shadow: 0 -2vw 4vw rgba(0, 0, 0, 0.1);
    padding: 3.5vw 4vw;
    display: flex;
    align-items: center;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.3, 0, 0, 1);
    z-index: 1000;
}

.za-notification.show {
    transform: translateY(0);
}

.za-notification-icon {
    margin-right: 2.5vw;
    flex-shrink: 0;
}

.za-notification-content {
    flex: 1;
    font-size: 3.5vw;
    line-height: 4.5vw;
    color: var(--text-title-color);
}

.za-notification-action {
    margin-left: 3vw;
    padding: 1.5vw 3vw;
    font-size: 3.5vw;
    line-height: 4.5vw;
    color: var(--theme-color);
    cursor: pointer;
    border: none;
    background: transparent;
    font-family: inherit;
    transition: opacity 0.3s;
}

.za-notification-action:active {
    opacity: 0.6;
}

.za-notification-close {
    margin-left: 2vw;
    cursor: pointer;
    flex-shrink: 0;
    color: var(--text-4);
    transition: opacity 0.3s;
}

.za-notification-close:active {
    opacity: 0.6;
}

.za-notification-success .za-notification-icon {
    color: #52c41a;
}

.za-notification-warning .za-notification-icon {
    color: var(--system-yellow);
}

.za-notification-error .za-notification-icon {
    color: var(--system-red);
}

.za-notification-info .za-notification-icon {
    color: var(--theme-color);
}

@media screen and (min-width: 670px) {
    .za-notification {
        padding: 3vw 3.5vw;
        left: 50%;
        right: auto;
        transform: translateX(-50%) translateY(100%);
        min-width: 40vw;
        max-width: 60vw;
        border-radius: 2.25vw 2.25vw 0 0;
    }
    
    .za-notification.show {
        transform: translateX(-50%) translateY(0);
    }
    
    .za-notification-icon {
        margin-right: 2vw;
    }
    
    .za-notification-content {
        font-size: 2.25vw;
        line-height: 3vw;
    }
    
    .za-notification-action {
        margin-left: 2.5vw;
        padding: 1.25vw 2.5vw;
        font-size: 2.25vw;
        line-height: 3vw;
    }
    
    .za-notification-close {
        margin-left: 1.5vw;
    }
}

@media screen and (min-width: 900px) and (min-aspect-ratio: 6/5) {
    .za-notification {
        padding: 1.875vw 2.1875vw;
        min-width: 25vw;
        max-width: 37.5vw;
        border-radius: 1.40625vw 1.40625vw 0 0;
    }
    
    .za-notification-icon {
        margin-right: 1.25vw;
    }
    
    .za-notification-content {
        font-size: 1.40625vw;
        line-height: 1.875vw;
    }
    
    .za-notification-action {
        margin-left: 1.5625vw;
        padding: 0.78125vw 1.5625vw;
        font-size: 1.40625vw;
        line-height: 1.875vw;
    }
    
    .za-notification-close {
        margin-left: 0.9375vw;
    }
}
